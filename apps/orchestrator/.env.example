# ── LLM backend selection ────────────────────────────────────
# One of: azure_openai (default) | openai | foundry
LLM_BACKEND=azure_openai

# Azure Speech (UAE North) — Entra-only when key is empty
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=uaenorth
AZURE_SPEECH_RESOURCE_ID=   # full ARM resource id (required for Entra auth)

# Azure OpenAI (when LLM_BACKEND=azure_openai)
AZURE_OPENAI_ENDPOINT=https://your-aoai.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=         # leave empty for Entra/managed-identity auth
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# OpenAI / OpenAI-compatible (when LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Microsoft Foundry project (when LLM_BACKEND=foundry)
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com
FOUNDRY_MODEL=gpt-4o

# Service auth
AUDVOICE_JWT_SECRET=replace-with-32-byte-random-base64
AUDVOICE_API_KEYS=devkey:tenant-dev   # comma-separated key:tenant pairs (dev only)

# Optional
REDIS_URL=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=

# Defaults
DEFAULT_VOICE=en-US-AvaMultilingualNeural
DEFAULT_LANGUAGES=ar-AE,ar-SA,en-US,en-GB
DEFAULT_MODEL=gpt-4.1
LOG_LEVEL=INFO
