{
  "name": "@audvoice/client",
  "version": "0.1.0",
  "description": "Browser + Node.js client SDK for AuDesign Voice — UAE-resident voice agent service",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["azure", "speech", "voice", "openai", "voice-live", "uae", "websocket", "agent", "sdk"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/audvoice"
  },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
